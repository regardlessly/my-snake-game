<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
    <key>Label</key>
    <string>com.caritahub.livekit</string>
    <key>ProgramArguments</key>
    <array>
        <string>/Users/timmy/.local/bin/livekit-server</string>
        <string>--config</string>
        <string>/Users/timmy/.config/livekit/config.yaml</string>
    </array>
    <key>WorkingDirectory</key>
    <string>/Users/timmy/.config/livekit</string>
    <key>RunAtLoad</key>
    <true/>
    <key>KeepAlive</key>
    <true/>
    <key>StandardOutPath</key>
    <string>/tmp/caritahub-livekit.log</string>
    <key>StandardErrorPath</key>
    <string>/tmp/caritahub-livekit.err</string>
</dict>
</plist>
